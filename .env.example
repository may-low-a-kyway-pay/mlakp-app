# Backend API base URL used by axios.
# Web/iOS simulator on the same machine:
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Android emulator talking to a backend on the host machine:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8080

# Physical device on the same Wi-Fi as your dev machine:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:8080

# Axios request timeout in milliseconds.
# Use a longer production timeout because Render free-tier services can cold-start slowly.
EXPO_PUBLIC_API_TIMEOUT_MS=60000

# Optional Android APK update checker. Leave empty to disable update prompts.
# In production, point this to a JSON file you can edit without rebuilding the APK.
# EXPO_PUBLIC_UPDATE_MANIFEST_URL=https://yourdomain.com/updates/android.json

# Optional landing page APK metadata.
# EXPO_PUBLIC_ANDROID_APK_URL=https://yourdomain.com/downloads/mlakp-v1.0.0.apk
# EXPO_PUBLIC_RELEASE_DATE=May 15, 2026

# Currency display and API payload defaults.
# The current backend accepts THB.
EXPO_PUBLIC_CURRENCY_CODE=THB
EXPO_PUBLIC_CURRENCY_SYMBOL=฿
